# Google Maps JavaScript API key (enable Maps JavaScript API in Cloud Console)
# Copy this file to `.env.local` and paste your key:
VITE_GOOGLE_MAPS_API_KEY=

# Optional Map ID for Advanced Markers (defaults to DEMO_MAP_ID for local testing)
# VITE_GOOGLE_MAPS_MAP_ID=

# Google OAuth 2.0 Web Client ID (Identity Services — login / signup)
# Create at https://console.cloud.google.com/apis/credentials
# Add http://localhost:5173 to Authorized JavaScript origins
VITE_GOOGLE_CLIENT_ID=

# MOCK ONLY — JWT signing secret shipped to the browser via Vite.
# Not production security. Leave unset to use the built-in mock default, or
# set a local value. Replace with backend-issued tokens when the auth API exists.
# VITE_JWT_SECRET=change-me-in-local-env
